<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sab.adagency.controller.RentalContractController">
   <top>
      <VBox spacing="6.0" styleClass="page-wrap">
         <children>
            <Label styleClass="section-title" text="Договори оренди білбордів та облік термінів" />
            <Label styleClass="section-subtitle" text="Оформлення оренди з перевіркою перетину дат на одному білборді" />
            <Separator />
         </children>
      </VBox>
   </top>
   <center>
      <SplitPane dividerPositions="0.50" orientation="VERTICAL">
         <items>
            <VBox spacing="10.0">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <children>
                        <Label style="-fx-font-weight: bold;" text="Список договорів" />
                        <Region HBox.hgrow="ALWAYS" />
                        <ComboBox fx:id="billboardFilterComboBox" promptText="Фільтр за білбордом" />
                        <ComboBox fx:id="paidFilterComboBox" promptText="Фільтр за оплатою" />
                        <Button fx:id="refreshButton" mnemonicParsing="false" onAction="#handleRefresh" text="Оновити" />
                     </children>
                  </HBox>
                  <TableView fx:id="contractTable" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn fx:id="idColumn" prefWidth="50.0" text="ID" />
                        <TableColumn fx:id="billboardColumn" prefWidth="170.0" text="Білборд" />
                        <TableColumn fx:id="clientColumn" prefWidth="170.0" text="Клієнт" />
                        <TableColumn fx:id="startDateColumn" prefWidth="100.0" text="Початок" />
                        <TableColumn fx:id="endDateColumn" prefWidth="100.0" text="Завершення" />
                        <TableColumn fx:id="daysColumn" prefWidth="80.0" text="Днів" />
                        <TableColumn fx:id="totalColumn" prefWidth="100.0" text="Сума" />
                        <TableColumn fx:id="paidColumn" prefWidth="110.0" text="Оплата" />
                     </columns>
                  </TableView>
               </children>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </VBox>
            <VBox spacing="15.0">
               <children>
                  <Label style="-fx-font-weight: bold;" text="Деталі договору оренди" />
                  <GridPane hgap="10.0" vgap="10.0">
                     <columnConstraints>
                        <ColumnConstraints hgrow="NEVER" minWidth="160.0" />
                        <ColumnConstraints hgrow="ALWAYS" />
                     </columnConstraints>
                     <children>
                        <Label text="Білборд:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <ComboBox fx:id="billboardComboBox" promptText="Виберіть білборд" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <Label text="Клієнт:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <ComboBox fx:id="clientComboBox" promptText="Виберіть клієнта" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <Label text="Дата початку:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <DatePicker fx:id="startDatePicker" promptText="Виберіть дату початку" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <Label text="Дата завершення:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                        <DatePicker fx:id="endDatePicker" promptText="Виберіть дату завершення" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                        <Label text="Оплачено:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                        <CheckBox fx:id="paidCheckBox" text="Договір оплачено" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                     </children>
                  </GridPane>
                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <children>
                        <Label style="-fx-font-size: 13px; -fx-font-weight: bold;" text="Зайнятість дат:" />
                        <Label fx:id="availabilityLabel" style="-fx-text-fill: #777;" text="—" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="checkAvailabilityButton" mnemonicParsing="false" onAction="#handleCheckAvailability" style="-fx-background-color: #FF9800; -fx-text-fill: white;" text="Перевірити зайнятість дат" />
                     </children>
                  </HBox>
                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <children>
                        <Label style="-fx-font-size: 14px; -fx-font-weight: bold;" text="Загальна вартість:" />
                        <Label fx:id="totalAmountLabel" style="-fx-font-size: 14px; -fx-text-fill: #1565C0;" text="0.00 грн" />
                     </children>
                  </HBox>
                  <HBox alignment="CENTER" spacing="10.0">
                     <children>
                        <Button fx:id="saveButton" mnemonicParsing="false" onAction="#handleSave" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Створити договір" />
                        <Button fx:id="updateButton" mnemonicParsing="false" onAction="#handleUpdate" style="-fx-background-color: #1976D2; -fx-text-fill: white;" text="Оновити договір" />
                        <Button fx:id="deleteButton" mnemonicParsing="false" onAction="#handleDelete" style="-fx-background-color: #f44336; -fx-text-fill: white;" text="Видалити договір" />
                        <Button fx:id="clearButton" mnemonicParsing="false" onAction="#handleClear" text="Очистити" />
                     </children>
                  </HBox>
               </children>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </VBox>
         </items>
      </SplitPane>
   </center>
</BorderPane>
