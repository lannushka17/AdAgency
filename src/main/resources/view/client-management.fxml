<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sab.adagency.controller.ClientController">
   <top>
      <VBox spacing="6.0" styleClass="page-wrap">
         <children>
            <Label styleClass="section-title" text="Управління клієнтами-рекламодавцями" />
            <Label styleClass="section-subtitle" text="Облік рекламодавців, контактів та VIP-статусу" />
            <Separator />
         </children>
      </VBox>
   </top>
   <center>
      <SplitPane dividerPositions="0.58" orientation="VERTICAL">
         <items>
            <VBox spacing="10.0">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <children>
                        <Label style="-fx-font-weight: bold;" text="Список клієнтів" />
                        <Region HBox.hgrow="ALWAYS" />
                        <TextField fx:id="searchField" promptText="Пошук за іменем/телефоном" />
                        <ComboBox fx:id="vipFilterComboBox" promptText="Фільтр за VIP" />
                        <Button fx:id="refreshButton" mnemonicParsing="false" onAction="#handleRefresh" text="Оновити" />
                     </children>
                  </HBox>
                  <TableView fx:id="clientTable" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn fx:id="idColumn" prefWidth="50.0" text="ID" />
                        <TableColumn fx:id="nameColumn" prefWidth="220.0" text="Назва/Ім'я" />
                        <TableColumn fx:id="phoneColumn" prefWidth="150.0" text="Телефон" />
                        <TableColumn fx:id="emailColumn" prefWidth="200.0" text="E-mail" />
                        <TableColumn fx:id="vipColumn" prefWidth="100.0" text="Статус" />
                     </columns>
                  </TableView>
               </children>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </VBox>
            <VBox spacing="15.0">
               <children>
                  <Label style="-fx-font-weight: bold;" text="Дані клієнта" />
                  <GridPane hgap="10.0" vgap="10.0">
                     <columnConstraints>
                        <ColumnConstraints hgrow="NEVER" minWidth="140.0" />
                        <ColumnConstraints hgrow="ALWAYS" />
                     </columnConstraints>
                     <children>
                        <Label text="Назва/Ім'я:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <TextField fx:id="nameField" promptText="Введіть назву компанії або ім'я" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <Label text="Телефон:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <TextField fx:id="phoneField" promptText="+380..." GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <Label text="E-mail:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <TextField fx:id="emailField" promptText="email@example.com" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <Label text="VIP-статус:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                        <CheckBox fx:id="vipCheckBox" text="Клієнт має VIP-статус (знижка 10%)" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                     </children>
                  </GridPane>
                  <HBox alignment="CENTER" spacing="10.0">
                     <children>
                        <Button fx:id="saveButton" mnemonicParsing="false" onAction="#handleSave" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Додати клієнта" />
                        <Button fx:id="updateButton" mnemonicParsing="false" onAction="#handleUpdate" style="-fx-background-color: #1976D2; -fx-text-fill: white;" text="Оновити клієнта" />
                        <Button fx:id="deleteButton" mnemonicParsing="false" onAction="#handleDelete" style="-fx-background-color: #f44336; -fx-text-fill: white;" text="Видалити клієнта" />
                        <Button fx:id="clearButton" mnemonicParsing="false" onAction="#handleClear" text="Очистити" />
                     </children>
                  </HBox>
               </children>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </VBox>
         </items>
      </SplitPane>
   </center>
</BorderPane>
